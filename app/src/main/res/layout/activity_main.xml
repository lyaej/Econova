<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1B5E20"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/tvGreeting"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#FFFFFF"
            android:textSize="14sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnHistory"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="History" android:textSize="11sp"
            android:textColor="#FFFFFF" android:backgroundTint="#2E7D32"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnClearData"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="Clear" android:textSize="11sp"
            android:textColor="#FFFFFF" android:backgroundTint="#C62828"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnAbout"
            android:layout_width="wrap_content" android:layout_height="32dp"
            android:text="About" android:textSize="11sp"
            android:textColor="#FFFFFF" android:backgroundTint="#2E7D32"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="EcoNova" android:textSize="20sp" android:textStyle="bold"
                android:textColor="#1B5E20" android:layout_marginBottom="2dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Track your digital carbon emissions"
                android:textSize="12sp" android:textColor="#555555" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="My Digital Consumption" android:textSize="13sp"
                android:textStyle="bold" android:textColor="#1B5E20" android:layout_marginBottom="4dp"/>
            <Spinner android:id="@+id/spinnerPreset"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/spinner_bg"
                android:entries="@array/presets" android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Select Products and Services" android:textSize="13sp"
                android:textStyle="bold" android:textColor="#1B5E20" android:layout_marginBottom="6dp"/>
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/productGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <LinearLayout android:id="@+id/hoursSection"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Daily Usage (hours per day)" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="#1B5E20" android:layout_marginBottom="8dp"/>
                <LinearLayout android:id="@+id/hoursContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Log Date: " android:textSize="13sp"
                        android:textStyle="bold" android:textColor="#1B5E20"/>
                    <TextView android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textSize="13sp" android:textColor="#333333"/>
                    <Button android:id="@+id/btnPickDate"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="Change Date" android:textSize="11sp"
                        android:backgroundTint="#388E3C" android:textColor="#FFFFFF"/>
                </LinearLayout>

                <Button android:id="@+id/btnSaveLog"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="Save Log" android:textSize="13sp"
                    android:backgroundTint="#388E3C" android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/footprintCard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="12dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:background="#FFFFFF">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="My Digital CO2 Footprint" android:textSize="14sp"
                        android:textStyle="bold" android:textColor="#1B5E20" android:layout_marginBottom="8dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:gravity="bottom" android:orientation="horizontal">
                        <TextView android:id="@+id/tvFootprintValue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.0" android:textSize="42sp"
                            android:textStyle="bold" android:textColor="#2E7D32"/>
                        <TextView android:id="@+id/tvFootprintUnit"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="kg CO2/year" android:textSize="12sp"
                            android:textColor="#555555" android:layout_marginStart="6dp"
                            android:layout_marginBottom="8dp"/>
                    </LinearLayout>

                    <TextView android:id="@+id/tvDailyValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Daily estimate: 0.0000 kg CO2" android:textSize="12sp"
                        android:textColor="#888888" android:layout_marginBottom="12dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E0E0E0" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Distribution by Product" android:textSize="12sp"
                        android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/ivPieChart"
                        android:layout_width="220dp" android:layout_height="220dp"
                        android:layout_gravity="center_horizontal" android:layout_marginBottom="8dp"/>
                    <LinearLayout android:id="@+id/legendContainer"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:layout_marginBottom="12dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E0E0E0" android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CO2 Intensity per Product" android:textSize="12sp"
                        android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/ivBarChart"
                        android:layout_width="match_parent" android:layout_height="220dp"
                        android:layout_marginBottom="12dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E0E0E0" android:layout_marginBottom="12dp"/>

                    <Button android:id="@+id/btnDownloadPng"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="Download PNG" android:textSize="11sp"
                        android:backgroundTint="#388E3C" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>