<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/green_dark"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About This App"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/green_dark"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is the proposed solution of 1st year IT students at Polytechnic University of the Philippines for their research titled:"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text='"Development of a Digital Carbon Footprint Tracker for Students Using Mobile Technology"'
                android:textSize="15sp"
                android:textStyle="bold|italic"
                android:textColor="@color/green_dark"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:lineSpacingMultiplier="1.4"/>

            <!-- Researcher 1 -->
            <include layout="@layout/item_researcher"
                android:id="@+id/researcher1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Researcher 2 -->
            <include layout="@layout/item_researcher"
                android:id="@+id/researcher2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Researcher 3 -->
            <include layout="@layout/item_researcher"
                android:id="@+id/researcher3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
